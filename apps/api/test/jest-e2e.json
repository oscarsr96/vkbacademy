{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/e2e/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
  },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@vkbacademy/shared$": "<rootDir>/../../packages/shared/src/index.ts"
  },
  "testTimeout": 30000,
  "maxWorkers": 1
}
